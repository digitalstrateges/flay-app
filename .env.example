# Flay v0.1 - Configuration
NODE_ENV=development
PORT=4000
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-secret
BASE_URL=http://localhost:4000
SITE_URL=http://localhost:4000
DB_PATH=data/flay.db

# Wave Payment
WAVE_MERCHANT_NAME=DIGITALSTRATEGE BUSINESS
WAVE_MERCHANT_PHONE=+2250759731990
WAVE_MERCHANT_EMAIL=contact@digitalstrateges.ci
WAVE_PAYMENT_URL=https://pay.wave.com/m/M_uv5jVAEPkSWs/c/ci/
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# CinetPay
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_API_PASSWORD=
CINETPAY_SECRET_KEY=

# WhatsApp
WHATSAPP_NUMBER=2250759731990
WHATSAPP_LINK=https://wa.me/2250759731990

# LLM Local (aucune API key requise)
LLM_MODEL=qwen2.5-0.5b
LLM_ENABLED=true
LLM_CACHE_SIZE=100

# Email (SMTP)
