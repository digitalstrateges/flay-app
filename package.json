{
  "name": "flay-app",
  "version": "19.0.0",
  "description": "Flay - Plateforme tout-en-un : showcase, e-commerce, CRM, reservations | DIGITALSTRATEGES",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "docker:build": "docker build -t flay-app .",
    "docker:run": "docker run -p 4000:4000 -v flay-data:/app/data flay-app",
    "docker:compose": "docker compose up -d",
    "health": "curl -s http://localhost:4000/api/health | head -c 200"
  },
  "engines": {
    "node": ">=18.0.0"
  },
