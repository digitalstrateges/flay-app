    "professionnel",
    "cote-divoire",
    "wave",
    "crm",
    "reservation",
    "market-intelligence"
  ],
  "author": "DIGITALSTRATEGES <contact@digitalstrateges.com>",
  "license": "UNLICENSED",
  "private": true,
  "type": "commonjs",
